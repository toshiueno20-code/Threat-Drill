# Threat Drill - Environment Variables

# Google Cloud Settings (optional in API-key mode)
GCP_PROJECT_ID=
GCP_LOCATION=us-central1

# Gemini API Key Settings (Google AI Studio)
API_KEY=your-google-ai-studio-api-key
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_DEEP_MODEL=gemini-2.5-pro
GEMINI_EMBED_MODEL=text-embedding-004
ENABLE_GEMINI_PLAYWRIGHT_MCP=false
PLAYWRIGHT_MCP_COMMAND=npx
PLAYWRIGHT_MCP_ARGS=@playwright/mcp@latest --headless --isolated --output-dir .playwright-mcp
GEMINI_MCP_MAX_REMOTE_CALLS=8
GEMINI_MCP_TIMEOUT_SECONDS=90
# Optional: overall cap for MCP session lifetime (should exceed GEMINI_MCP_TIMEOUT_SECONDS).
GEMINI_MCP_HARD_TIMEOUT_SECONDS=135

# UI: in-memory security event buffer size (for /api/v1/security/events).
SECURITY_EVENTS_BUFFER=200

# Backward-compatible Vertex setting (optional)
VERTEX_AI_ENDPOINT=

# Firestore Settings
FIRESTORE_DATABASE=(default)

# Pub/Sub Settings
PUBSUB_SECURITY_EVENTS_TOPIC=threatdrill-security-events
PUBSUB_FEEDBACK_LOOP_TOPIC=threatdrill-feedback-loop
PUBSUB_POLICY_UPDATES_TOPIC=threatdrill-policy-updates
PUBSUB_RED_TEAM_FINDINGS_TOPIC=threatdrill-red-team-findings

# Server Settings
HOST=0.0.0.0
PORT=8080
WORKERS=4
RELOAD=false

# Security Settings
ENABLE_DEEP_THINK=true
DEEP_THINK_CONFIDENCE_THRESHOLD=0.75
MAX_REQUEST_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=1000

# Logging
LOG_LEVEL=INFO
JSON_LOGS=true

# Redis Cache (Optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Monitoring
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Red Team Target Allowlist / Sandbox Verification
# Allow additional non-sandbox domains for dynamic assessments (comma-separated).
# Example: THREATDRILL_ALLOWED_DOMAINS="staging.example.com,my-internal-service"
THREATDRILL_ALLOWED_DOMAINS=
#
# Shared secret used to verify Cloud Run sandbox targets for Playwright-based checks
# (e.g. Red Team "Scenario" and "Dynamic Checks"). The target app must implement:
#   GET /.well-known/threatdrill-sandbox
# and use the same THREATDRILL_SANDBOX_SECRET.
THREATDRILL_SANDBOX_SECRET=change-me

# Authentication (Optional)
REQUIRE_AUTHENTICATION=false
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
